# Finnhub API key (free at https://finnhub.io/register)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Google Calendar ID for your earnings calendar
# Find this in Google Calendar > Settings > calendar ID (looks like xxx@group.calendar.google.com)
GOOGLE_CALENDAR_ID=your_calendar_id_here

# Path to your Google service account credentials JSON file
GOOGLE_CREDENTIALS_PATH=credentials.json

# Coverage Manager exports directory (source of truth for tickers and tiers)
# If not set, falls back to tickers.txt or TICKERS env var
COVERAGE_MANAGER_PATH=C:/Users/jroyp/Dropbox/Claude Folder/Coverage Manager

# Timezone for calendar event times
TIMEZONE=America/New_York

# TickTick (execution surface for earnings review tasks)
# Get your access token from developer.ticktick.com (expires ~every 180 days)
# TICKTICK_ACCESS_TOKEN=your_token_here
# Fallback list ID — used if auto list creation fails
# TICKTICK_LIST_EARNINGS=your_list_id_here

# Slack webhook for #earnings channel (used by --weekly-digest, heartbeat,
# and as fallback when bot-token vars below are unset)
# SLACK_WEBHOOK_EARNINGS=https://hooks.slack.com/services/...

# Slack bot token + channel ID. When set, cross-check / unseen / urgent
# alerts post per-disagreement threads and `--check-replies` polls the
# threads to drive resolution from in-thread reply commands.
# Required scopes: chat:write, channels:history (or groups:history).
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C0123456789

# Email recipient for weekly digest drafts (built via Gmail MCP)
# EMAIL_TO=you@example.com

# --- Legacy (only used if Coverage Manager exports are not found) ---
# Comma-separated list of tickers to track
# TICKERS=UNH,CI,HUM,ELV,CNC,MOH,CVS,HCA,THC,UHS
